# Environment Configuration
NODE_ENV=development
PORT=3000

# Microservice Ports
USER_SERVICE_PORT=3001
PROJECT_SERVICE_PORT=3002
ASSET_SERVICE_PORT=3003
SEARCH_SERVICE_PORT=3004

# Firebase Admin SDK Credentials
# Option 1: Use service account JSON file (recommended for development)
# Place your serviceAccountKey.json in the backend directory

# Option 2: Use environment variable (recommended for production)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id",...}

# CORS Settings (optional)
# CORS_ORIGIN=http://localhost:3000

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
