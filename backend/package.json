{
  "name": "acm-project-archive-backend",
  "version": "1.0.0",
  "description": "Backend API for ACM Project Archive Platform - Authentication, User Management, and Project Write Operations",
  "main": "api-gateway/app.js",
  "scripts": {
    "start": "concurrently \"npm run start:gateway\" \"npm run start:user\" \"npm run start:project\" \"npm run start:asset\" \"npm run start:search\"",
    "dev": "concurrently \"npm run dev:gateway\" \"npm run dev:user\" \"npm run dev:project\" \"npm run dev:asset\" \"npm run dev:search\"",
    "start:gateway": "node api-gateway/app.js",
    "dev:gateway": "nodemon api-gateway/app.js",
    "start:user": "node user-service/app.js",
    "dev:user": "nodemon user-service/app.js",
    "start:project": "node project-service/app.js",
    "dev:project": "nodemon project-service/app.js",
    "start:asset": "node asset-service/app.js",
    "dev:asset": "nodemon asset-service/app.js",
    "start:search": "node search-service/app.js",
    "dev:search": "nodemon search-service/app.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:services": "node test-services.js"
  },
  "keywords": [
    "acm",
    "project-archive",
    "firebase",
    "express",
    "api"
  ],
  "author": "Hemanth",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.6",
    "cloudinary": "^2.9.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "firebase-admin": "^12.0.0",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
